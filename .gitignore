.venv/
__pycache__/
*.pyc
.pytest_cache/
data/settings.json
data/settings.json.*
data/logs/
# User-placed model weights (SDXL checkpoint, buffalo_l, inswapper, matting
# model, …). Large + partly non-commercial-licensed — never committed; each
# is pointed at by a models.image.* settings key (relative paths resolve here).
models/
# Runtime character data (records, references, bootstrap candidates, vetted
# sets, catalogs) — user data produced by the app, like settings/logs above.
# The 3c validation set for 3d training lives here on THIS machine only.
data/characters/
# Runtime builder data (Stage 5: personas/scenes/events/scenarios + generated
# scene backgrounds) — user data produced by the app, like data/characters/.
# The BUNDLED builder option files live under app/data/builders/ and ARE tracked.
data/builders/
# Runtime job records (Stage 5.5a: data/jobs/<job_id>.json, reaped at boot).
data/jobs/
